# Frontend env (Vite). Copy to .env.local to override.
# Where the API lives. In dev, Vite proxies /api to this (see vite.config.js).
VITE_API_TARGET=http://127.0.0.1:8787
# When serving the built app from a different origin (e.g. Cloudflare tunnel),
# set an absolute base instead and the api client will use it:
# VITE_API_BASE=https://wom.yourdomain.com
